# Text normalization
* text=auto

# Build artifacts and binaries
*.hap binary
*.app binary
*.app.zip binary
*.a binary
*.so binary
*.dll binary
*.dylib binary
*.exe binary
*.zip binary
*.7z binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.rar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary

