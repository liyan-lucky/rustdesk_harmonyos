import preferences from '@ohos.data.preferences';
import i18n from '@ohos.i18n';
import { AppContextService } from './AppContextService';

export class I18nService {
  private static instance: I18nService;
  private currentLocale: string = 'zh-CN';
  private currentLanguage: string = 'system';
  private translations: Map<string, string> = new Map();
  private preferences: preferences.Preferences | null = null;
  private initialized: boolean = false;

  private constructor() {
    const systemLocale = this.resolveSystemLocale();
    this.currentLocale = systemLocale;
    if (systemLocale === 'en') {
      this.loadEnglishTranslations();
    } else {
      this.loadChineseTranslations();
    }
    this.syncToAppStorage();
    void this.loadSavedLocale();
  }

  static getInstance(): I18nService {
    if (!I18nService.instance) {
      I18nService.instance = new I18nService();
    }
    return I18nService.instance;
  }

  translate(key: string): string {
    return this.translations.get(key) ?? key;
  }

  getCurrentLocale(): string {
    return this.currentLocale;
  }

  getCurrentLanguage(): string {
    return this.currentLanguage;
  }

  private resolveSystemLocale(): string {
    try {
      const systemLocale = i18n.System.getSystemLanguage();
      if (systemLocale && systemLocale.length > 0) {
        return systemLocale.startsWith('zh') ? 'zh-CN' : 'en';
      }
    } catch (e) {
      console.warn('resolveSystemLocale failed', JSON.stringify(e));
    }
    return 'zh-CN';
  }

  setLanguage(language: string): void {
    console.info(`[I18N] setLanguage called: ${language}, currentLocale: ${this.currentLocale}`);
    this.currentLanguage = language;
    let targetLocale: string;
    if (language === 'system') {
      targetLocale = this.resolveSystemLocale();
    } else {
      targetLocale = language === 'zh' ? 'zh-CN' : 'en';
    }
    this.currentLocale = targetLocale;
    if (targetLocale === 'en') {
      this.loadEnglishTranslations();
    } else {
      this.loadChineseTranslations();
    }
    console.info(`[I18N] after load, translate('Language')=${this.translate('Language')}, translate('Remote ID')=${this.translate('Remote ID')}`);
    this.syncToAppStorage();
    console.info(`[I18N] syncToAppStorage done, i18nVersion=${AppStorage.get<number>('i18nVersion')}`);
    if (this.preferences) {
      void this.preferences.put('language', language).then(() => {
        return this.preferences!.put('locale', this.currentLocale);
      }).then(() => {
        void this.preferences!.flush();
      }).catch((error: Object) => {
        console.error('save language failed', JSON.stringify(error));
      });
    }
  }

  private syncToAppStorage(): void {
    const newVersion = Date.now();
    AppStorage.setOrCreate<number>('i18nVersion', newVersion);
    AppStorage.setOrCreate<number>('forceRefreshVersion', newVersion);
  }

  setLocale(locale: string): void {
    const changed = this.currentLocale !== locale;
    this.currentLocale = locale;
    if (locale === 'en') {
      this.loadEnglishTranslations();
    } else {
      this.loadChineseTranslations();
    }
    if (changed) {
      this.syncToAppStorage();
    }
    if (this.preferences) {
      void this.preferences.put('locale', locale).then(() => {
        void this.preferences!.flush();
      }).catch((error: Object) => {
        console.error('save locale failed', JSON.stringify(error));
      });
    }
  }

  private async loadSavedLocale(): Promise<void> {
    try {
      const context = AppContextService.getContext();
      if (!context) {
        return;
      }
      this.preferences = await preferences.getPreferences(context, 'rustdesk_settings');
      const savedLanguage = await this.preferences.get('language', 'system') as string;
      this.currentLanguage = savedLanguage;
      if (savedLanguage === 'system') {
        const systemLocale = this.resolveSystemLocale();
        this.currentLocale = systemLocale;
        if (systemLocale === 'en') {
          this.loadEnglishTranslations();
        } else {
          this.loadChineseTranslations();
        }
      } else {
        const savedLocale = await this.preferences.get('locale', 'zh-CN') as string;
        this.currentLocale = savedLocale;
        if (savedLocale === 'en') {
          this.loadEnglishTranslations();
        } else {
          this.loadChineseTranslations();
        }
      }
      this.syncToAppStorage();
    } catch (error) {
      console.error('load locale failed', JSON.stringify(error));
    }
  }

  onSystemLocaleChanged(): void {
    if (this.currentLanguage !== 'system') {
      return;
    }
    const newLocale = this.resolveSystemLocale();
    if (newLocale === this.currentLocale) {
      return;
    }
    this.currentLocale = newLocale;
    if (newLocale === 'en') {
      this.loadEnglishTranslations();
    } else {
      this.loadChineseTranslations();
    }
    this.syncToAppStorage();
  }

